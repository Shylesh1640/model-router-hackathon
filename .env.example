# OpenRouter API key (get one at https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-...here

# Server
DASHBOARD_PORT=8080
LOG_LEVEL=INFO

# Routing
CASCADE_ENABLED=true
REQUEST_TIMEOUT=60

# Langfuse observability (optional — skip to disable)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Scraper / Benchmarks
LAUNCH_HOOK_ENABLED=true
REFRESH_MODELS_ON_START=true
