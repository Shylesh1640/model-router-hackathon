# OpenRouter API key (get one at https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-...your-key-here

# Server
DASHBOARD_PORT=8081
LOG_LEVEL=INFO

# Routing
CASCADE_ENABLED=true
CASCADE_MAX_HOPS=2
CASCADE_MAX_BUDGET=10000
REQUEST_TIMEOUT=60
RATE_LIMIT_RETRIES=3

# Circuit breaker (skip failing models temporarily)
CB_COOLDOWN=60
CB_MAX_FAILURES=3

# Langfuse observability (optional — skip to disable)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Scraper / Benchmarks
LAUNCH_HOOK_ENABLED=true
REFRESH_MODELS_ON_START=true
