# OpenRouter API key (get one at https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Server
DASHBOARD_PORT=8080
LOG_LEVEL=INFO

# Routing
CASCADE_ENABLED=true
REQUEST_TIMEOUT=60
DECOMPOSITION_ENABLED=true

# Scraper / Benchmarks
LAUNCH_HOOK_ENABLED=true
REFRESH_MODELS_ON_START=true
